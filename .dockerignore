# =============================================
# .dockerignore - Archivos excluidos del build
# =============================================

# Dependencias
node_modules
npm-debug.log
yarn-debug.log
yarn-error.log

# Build outputs locales (el contenedor los genera)
dist
build

# Git
.git
.gitignore

# IDE
.idea
.vscode
*.swp
*.swo

# Archivos de entorno (usar variables de docker-compose)
.env
.env.*
!.env.example

# Tests
coverage
.nyc_output
*.test.ts
*.spec.ts

# Documentación
docs
*.md
!README.md

# Docker (evitar recursión)
Dockerfile*
docker-compose*
.docker*

# OS
.DS_Store
Thumbs.db

# Logs
logs
*.log

# Temporal
tmp
temp
.tmp
.temp

# Prisma (se genera en el container)
prisma/migrations/*.sql.backup
