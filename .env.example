# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=hotel_admin
DB_PASSWORD=your_secure_password
DB_NAME=hotel_management
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

# JWT
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# CORS
CORS_ORIGIN=http://localhost:3000

# PgAdmin
PGADMIN_EMAIL=admin@hotel.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# Swagger
SWAGGER_TITLE=Hotel Management API
SWAGGER_DESCRIPTION=API for hotel management system
SWAGGER_VERSION=1.0
