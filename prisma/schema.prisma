generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  MAINTENANCE
  OUT_OF_SERVICE
}

enum RoomType {
  SINGLE
  DOUBLE
  TWIN
  SUITE
  DELUXE
  PRESIDENTIAL
  FAMILY
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum EmployeeRole {
  ADMIN
  MANAGER
  RECEPTIONIST
  HOUSEKEEPING
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum DocumentType {
  PASSPORT
  NATIONAL_ID
  DRIVERS_LICENSE
  OTHER
}

enum CleaningStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum ServiceCategory {
  RESTAURANT
  SPA
  TRANSPORT
  LAUNDRY
  ROOM_SERVICE
  OTHER
}

// ==================== MODELS ====================

model Employee {
  id                           String                 @id @default(uuid())
  firstName                    String                 @map("first_name")
  lastName                     String                 @map("last_name")
  email                        String                 @unique
  password                     String
  role                         EmployeeRole           @default(RECEPTIONIST)
  status                       EmployeeStatus         @default(ACTIVE)
  refreshTokens                RefreshToken[]
  checkIns                     CheckInOut[]           @relation("CheckInEmployee")
  checkOuts                    CheckInOut[]           @relation("CheckOutEmployee")
  cleaningTasks                CleaningTask[]
  createdMultiRoomReservations MultiRoomReservation[]
  createdReservations          Reservation[]          @relation("CreatedByEmployee")
  createdAt                    DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                    DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt                    DateTime?              @map("deleted_at") @db.Timestamptz(3)

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("employees")
}

model RefreshToken {
  id         String    @id @default(uuid())
  token      String    @unique
  employeeId String    @map("employee_id")
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(3)

  @@index([token])
  @@index([employeeId])
  @@map("refresh_tokens")
}

model Customer {
  id                    String                 @id @default(uuid())
  firstName             String                 @map("first_name")
  lastName              String                 @map("last_name")
  email                 String                 @unique
  phone                 String?
  documentType          DocumentType           @default(NATIONAL_ID) @map("document_type")
  documentNumber        String                 @map("document_number")
  address               String?
  nationality           String?
  birthDate             DateTime?              @map("birth_date") @db.Timestamptz(3)
  multiRoomReservations MultiRoomReservation[]
  reservations          Reservation[]
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt             DateTime?              @map("deleted_at") @db.Timestamptz(3)

  @@unique([documentType, documentNumber])
  @@index([email])
  @@index([lastName])
  @@map("customers")
}

model Room {
  id            String         @id @default(uuid())
  number        String         @unique
  floor         Int
  type          RoomType       @default(SINGLE)
  status        RoomStatus     @default(AVAILABLE)
  pricePerNight Decimal        @map("price_per_night") @db.Decimal(10, 2)
  capacity      Int            @default(2)
  description   String?
  images        String[]       @default([])
  amenities     String[]       @default([])
  reservations  Reservation[]
  cleaningTasks CleaningTask[]
  checkInOuts   CheckInOut[]
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt     DateTime?      @map("deleted_at") @db.Timestamptz(3)

  @@index([number])
  @@index([status])
  @@index([type])
  @@index([floor])
  @@map("rooms")
}

model Reservation {
  id                     String                @id @default(uuid())
  reservationCode        String                @unique @map("reservation_code")
  customerId             String                @map("customer_id")
  customer               Customer              @relation(fields: [customerId], references: [id])
  multiRoomReservationId String?               @map("multi_room_reservation_id")
  multiRoomReservation   MultiRoomReservation? @relation(fields: [multiRoomReservationId], references: [id])
  roomId                 String                @map("room_id")
  room                   Room                  @relation(fields: [roomId], references: [id])
  checkInDate            DateTime              @map("check_in_date") @db.Timestamptz(3)
  checkOutDate           DateTime              @map("check_out_date") @db.Timestamptz(3)
  adults                 Int                   @default(1)
  children               Int                   @default(0)
  totalAmount            Decimal               @map("total_amount") @db.Decimal(10, 2)
  status                 ReservationStatus     @default(PENDING)
  notes                  String?
  createdById            String?               @map("created_by_id")
  createdBy              Employee?             @relation("CreatedByEmployee", fields: [createdById], references: [id])
  checkInOut             CheckInOut?
  reservationServices    ReservationService[]
  createdAt              DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt              DateTime?             @map("deleted_at") @db.Timestamptz(3)

  @@index([reservationCode])
  @@index([customerId])
  @@index([multiRoomReservationId])
  @@index([roomId])
  @@index([status])
  @@index([checkInDate, checkOutDate])
  @@map("reservations")
}

model MultiRoomReservation {
  id              String        @id @default(uuid())
  reservationCode String        @unique @map("reservation_code")
  customerId      String        @map("customer_id")
  customer        Customer      @relation(fields: [customerId], references: [id])
  checkInDate     DateTime      @map("check_in_date") @db.Timestamptz(3)
  checkOutDate    DateTime      @map("check_out_date") @db.Timestamptz(3)
  notes           String?
  createdById     String?       @map("created_by_id")
  createdBy       Employee?     @relation(fields: [createdById], references: [id])
  reservations    Reservation[]
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz(3)

  @@index([reservationCode])
  @@index([customerId])
  @@index([checkInDate, checkOutDate])
  @@map("multi_room_reservations")
}

model AdditionalService {
  id                  String               @id @default(uuid())
  name                String
  description         String?
  price               Decimal              @db.Decimal(10, 2)
  category            ServiceCategory      @default(OTHER)
  active              Boolean              @default(true)
  reservationServices ReservationService[]
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt           DateTime?            @map("deleted_at") @db.Timestamptz(3)

  @@index([category])
  @@index([active])
  @@map("additional_services")
}

model ReservationService {
  id            String            @id @default(uuid())
  reservationId String            @map("reservation_id")
  reservation   Reservation       @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  serviceId     String            @map("service_id")
  service       AdditionalService @relation(fields: [serviceId], references: [id])
  quantity      Int               @default(1)
  unitPrice     Decimal           @map("unit_price") @db.Decimal(10, 2)
  totalPrice    Decimal           @map("total_price") @db.Decimal(10, 2)
  notes         String?
  serviceDate   DateTime          @default(now()) @map("service_date") @db.Timestamptz(3)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([reservationId])
  @@index([serviceId])
  @@map("reservation_services")
}

model CheckInOut {
  id                 String      @id @default(uuid())
  reservationId      String      @unique @map("reservation_id")
  reservation        Reservation @relation(fields: [reservationId], references: [id])
  roomId             String      @map("room_id")
  room               Room        @relation(fields: [roomId], references: [id])
  checkInTime        DateTime?   @map("check_in_time") @db.Timestamptz(3)
  checkInEmployeeId  String?     @map("check_in_employee_id")
  checkInEmployee    Employee?   @relation("CheckInEmployee", fields: [checkInEmployeeId], references: [id])
  checkOutTime       DateTime?   @map("check_out_time") @db.Timestamptz(3)
  checkOutEmployeeId String?     @map("check_out_employee_id")
  checkOutEmployee   Employee?   @relation("CheckOutEmployee", fields: [checkOutEmployeeId], references: [id])
  notes              String?
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([reservationId])
  @@index([roomId])
  @@map("check_in_outs")
}

model CleaningTask {
  id            String         @id @default(uuid())
  roomId        String         @map("room_id")
  room          Room           @relation(fields: [roomId], references: [id])
  employeeId    String?        @map("employee_id")
  employee      Employee?      @relation(fields: [employeeId], references: [id])
  status        CleaningStatus @default(PENDING)
  scheduledDate DateTime       @map("scheduled_date") @db.Timestamptz(3)
  completedDate DateTime?      @map("completed_date") @db.Timestamptz(3)
  notes         String?
  priority      Int            @default(1)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([roomId])
  @@index([employeeId])
  @@index([status])
  @@index([scheduledDate])
  @@map("cleaning_tasks")
}

model AuditLog {
  id         String   @id @default(uuid())
  tableName  String   @map("table_name")
  recordId   String   @map("record_id")
  action     String
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  employeeId String?  @map("employee_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([tableName, recordId])
  @@index([employeeId])
  @@index([createdAt])
  @@map("audit_logs")
}
